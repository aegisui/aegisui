{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ui",
  "projectType": "library",
  "sourceRoot": "packages/ui/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/ui"],
      "options": {
        "command": "ng-packagr -p packages/ui/ng-package.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/ui",
        "command": "vitest run"
      }
    }
  }
}
