{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "tokens",
  "projectType": "library",
  "sourceRoot": "packages/tokens/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/tokens"],
      "options": {
        "cwd": "packages/tokens",
        "command": "node scripts/build-tokens.mjs"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/tokens",
        "command": "vitest run"
      }
    }
  }
}
