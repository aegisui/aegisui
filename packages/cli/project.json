{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "cli",
  "projectType": "library",
  "sourceRoot": "packages/cli/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/dist/packages/cli"],
      "options": {
        "command": "tsc -p packages/cli/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/cli",
        "command": "vitest run"
      }
    }
  }
}
