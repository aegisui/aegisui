{
  "name": "aegisui-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "nx": "nx",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish --tag next",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "peer-floor": "node scripts/check-peer-floor.mjs",
    "contracts": "node scripts/check-contracts.mjs",
    "size": "size-limit"
  },
  "devDependencies": {
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@changesets/cli": "2.31.0",
    "@eslint/css": "1.4.0",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@size-limit/file": "12.1.0",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "ng-packagr": "22.0.1",
    "nx": "23.0.2",
    "prettier": "3.9.5",
    "rxjs": "7.8.2",
    "size-limit": "12.1.0",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vitest": "4.1.10"
  }
}
