{
  "name": "aegisui-workspace",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.12.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "nx": "nx",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish --tag next",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "peer-floor": "node scripts/check-peer-floor.mjs",
    "contracts": "node scripts/check-contracts.mjs",
    "size": "size-limit",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build -o dist/storybook"
  },
  "devDependencies": {
    "@aegisui/generators": "workspace:*",
    "@analogjs/vite-plugin-angular": "2.6.3",
    "@angular/animations": "22.0.6",
    "@angular/build": "22.0.6",
    "@angular/cli": "22.0.6",
    "@angular/common": "22.0.6",
    "@angular/compiler": "22.0.6",
    "@angular/compiler-cli": "22.0.6",
    "@angular/core": "22.0.6",
    "@angular/platform-browser": "22.0.6",
    "@axe-core/playwright": "4.11.0",
    "@changesets/cli": "2.31.0",
    "@eslint/css": "1.4.0",
    "@eslint/js": "10.0.1",
    "@nx/devkit": "23.0.2",
    "@playwright/test": "1.61.1",
    "@size-limit/file": "12.1.0",
    "@storybook/addon-docs": "10.5.1",
    "@storybook/angular-vite": "10.5.1",
    "@swc-node/register": "1.10.10",
    "@swc/core": "1.13.5",
    "@testing-library/angular": "19.4.1",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@vitest/coverage-v8": "4.1.10",
    "axe-core": "4.11.0",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "jsdom": "27.0.0",
    "ng-packagr": "22.0.1",
    "nx": "23.0.2",
    "prettier": "3.9.5",
    "rxjs": "7.8.2",
    "size-limit": "12.1.0",
    "storybook": "10.5.1",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.5",
    "vite-tsconfig-paths": "5.1.4",
    "vitest": "4.1.10"
  }
}
